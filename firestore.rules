rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
          exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /users/{userId} {
      // Admin can view any user profile, normal users can only view their own
      allow get: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      // Only admin can list all users
      allow list: if isAdmin();
      // Users can update only their own profile, admin can also update if needed
      allow create, update: if isAdmin() ||
          (isSignedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();

      match /bridal_enquiries/{id} {
        allow create, read, update, delete: if isAdmin() ||
            (isSignedIn() && request.auth.uid == userId);
      }

      match /salon_owner_enquiries/{id} {
        allow create, read, update, delete: if isAdmin() ||
        (isSignedIn() && request.auth.uid == userId);
      }
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Admin membership documents (one doc per admin uid)
    match /admins/{adminId} {
      // Users can check their own admin membership; admins can read any admin doc.
      allow get: if (isSignedIn() && request.auth.uid == adminId) || isAdmin();
      allow list: if false;

      // Admin membership must be managed only from Firebase Console/Admin SDK.
      allow create, update, delete: if false;
    }

    match /announcements/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /coupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{id} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /alerts/{id} {
      allow read, write: if isAdmin();
    }

    match /mail/{id} {
      allow create: if isSignedIn();
      allow read, update, delete: if false;
    }

    match /bridal_enquiries/{id} {
      allow create: if isSignedIn() &&
          request.resource.data.userId == request.auth.uid;
      allow get: if isAdmin() ||
          (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /salon_owner_enquiries/{id} {
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow get: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /reviews/{id} {
      allow read: if true;
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.approved == false;
      allow update: if isAdmin() ||
        (isSignedIn() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.approved == resource.data.approved);
      allow delete: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
